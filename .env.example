# OpenAssetIO: path to a default manager configuration file (TOML).
# Example: OPENASSETIO_DEFAULT_CONFIG=/abs/path/to/openassetio.config.toml
OPENASSETIO_DEFAULT_CONFIG=

# Optional: additional plugin search paths (for plugins that cannot use Python
# importlib hooks, e.g. C++ plugins).
# OPENASSETIO_PLUGIN_PATH=