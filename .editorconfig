root = true

[*]
indent_size = 4
indent_style = space
max_line_length = 120
ij_visual_guides = 88

[.editorconfig]
max_line_length = 88

[{*.har,*.jsb2,*.jsb3,*.json,*.jsonc,*.postman_collection,*.postman_collection.json,*.postman_environment,*.postman_environment.json,.babelrc,.eslintrc,.prettierrc,.stylelintrc,.ws-context,jest.config}]
indent_size = 2

[{*.markdown,*.md}]
max_line_length = 99

[*.toml]
max_line_length = 88

[{*.yaml,*.yml}]
indent_size = 2
